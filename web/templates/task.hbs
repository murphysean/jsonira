<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Mrfy.io Task {{task.title}}</title>
        <meta charset="UTF-8">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
        <style type="text/css">
            section.attributes{
                display: flex;
                flex-direction: row;
                flex-wrap: wrap;
                border: 2px dotted gray;
            }

            section.attributes article{
                background-color: lightgray;
                margin: 2px;
                flex: 1 1 auto;
                align-content: center;
            }

            section.comments{
                padding-left: 5px;
            }

            section.comments article{
                margin: 5px;
                padding-left: 5px;
                border-left: 2px solid brown;
                background-color: beige;
            }

            section.comments article footer{
                font-size: x-small;
                text-align: end;
            }
        </style>
        <script>
            //Embed the task into the page
            let task_id = {{task.id}};
            const subject_id = {{subject.id}};
            const subject_name = "{{subject.name}}";
            const subject_email = "{{subject.email}}";


//Sends a patch request with the given patch document as a patch
async function patch_task(id,patch){
    try{
        let request = new Request("/api/tasks/" + id, {
            method: "PATCH",
            headers: { "content-type": "application/json-patch+json" },
            body: JSON.stringify(patch),
        });
        const response = await fetch(request);
        if (response.ok){
            const json = await response.json();
            task = json;
        } else {
            throw new Error(`Response status: ${response.status}`)
        }
    } catch (error) {
        console.log(error);
    }
}
        </script>
    </head>
    <body>
        <header><h1>TASK-{{task.id}}: {{task.title}}</h1></header>
        <nav>
            <p><a href="/index.html"/>Home</a></p>
            <p><a href="/board.html">Board</a></p>
        </nav>
        <section id="attributes" class="attributes">
            <article>
                <label for="title">Title:</label>
                <span id="title">{{task.title}}</span>
            </article>
            <article>
                <label>Reporter:</label>
                <span id="reporter">{{task.reporter.name}}</span>
            </article>
            <article>
                <label for="watchers">Watchers:</label>
                <ul id="watchers">
                {{#each task.watchers}}
                    <li id="watcher-{{id}}" name="watcher">{{name}}</li>
                {{/each}}
                </ul>
            </article>
            <article>
                <label for="circle">Circle:</label>
                <span id="circle" name="circle">{{task.circle}}</span>
            </article>
            <article>
                <label for="assignee">Assignee:</label>
                <span id="assignee" name="assignee">{{task.assignee.name}}</span>
            </article>
            <article>
                <label for="priority">Priority:</label>
                <span id="priority" name="priority">{{task.priority}}</span>
            </article>
            <article>
                <label for="estimate">Estimate (8601 time span... P1y2m3dT4h5m6s):</label>
                <span id="estimate" name="estimate">{{task.estimate}}</span>
            </article>
            <article>
                <label for="points">Points:</label>
                <span id="points" name="points">{{task.points}}</span>
            </article>
            <article>
                <label for="state">State:</label>
                <span id="state" name="state">{{task.state.state}}</span>
            </article>
            <article>
                <label for="tags">Tags:</label>
                <ul id="tags">
                {{#each task.tags}}
                    <li id="tag-{{this}}" name="tag">{{this}}</li>
                {{/each}}
                </form>
            </article>
            <article>
                <time>Created: {{task.created}}</time>
            </article>
            <article>
                <time>Updated: {{task.updated}}</time>
            </article>
            <article>
            <article>
                <label for="due">Due:</label>
                <time id="due" name="due" value="{{task.due}}"/>
            </article>
        </section>
        <script>
            function add_comment(){
                const now = new Date;
                const comment_input = document.getElementById("comment-input");
                const comment = comment_input.value;
                patch_task(task_id, [
                    {"op": "add", "path": "/comments/-", "value": {
                            subject: {
                                id: subject_id,
                                name: subject_name,
                                email: subject_email,
                            },
                            comment: comment,
                            content_type: "text/plain",
                            created: now.toISOString(),
                        },
                    }
                ]);
                comment_input.value = "";
                //TODO Add a section for this comment
                const comments_section = document.getElementById("comments");
                let ce = document.createElement("article");
                ce.name = "comment"
                ce.className = "comment"
                ce.innerHTML = "<div>"+comment+"</div><footer>By "+subject_name+" right now</footer>";
                comments_section.appendChild(ce);
            }
        </script>
        <section>
            <header><h3>Comments</h3></header>
            <section id="comments" class="comments">
                {{#each task.comments}}<article name="comment" class="comment">
                    {{#if comment}}<div>{{comment}}</div>{{/if}}
                    <footer>By {{subject.name}} on {{created}}</footer>
                </article>{{/each}}{{#if subject.id}}
            </section>
            <input id="comment-input" type="text">
            <input type="button" value="Add Comment" onclick="add_comment()"/>{{/if}}
        </section>
            <p>Reactions: {{task.reactions}}</p>
            <p>Reviews: {{task.reviews}}</p>
            <p>History: {{task.history}}</p>
        <section id="history">
            {{#each task.history}}<article id="history-{{@index}}">
                <div>Updates by {{subject.name}} on {{patched}}</div>
            </article>{{/each}}
        </section>
        <footer>{{task.history}}</footer>
    </body>
</html>